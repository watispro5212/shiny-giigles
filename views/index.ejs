<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus Protocol | Elite Community Tools</title>
    <meta name="description" content="NexusBot is a premium Discord bot providing advanced network economy, high-stakes modules, and elite moderation capabilities.">
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="bg-canvas"></div>
    
    <%- include('partials/header', { isHome: true }) %>

    <div class="container">
        <header class="reveal">
            <h1 class="hero-title hero-glow">Initialize Nexus Protocol.</h1>
            <p class="hero-subtitle">NexusBot provides authorized access to professional network economy, high-stakes interfaces, and elite node moderation tools.</p>
            <div class="hero-btns">
                <% if (user) { %>
                    <a href="/dashboard" class="btn btn-primary">Access Dashboard</a>
                <% } else { %>
                    <a href="/api/auth/login" class="btn btn-primary">Initialize Access</a>
                <% } %>
                <a href="https://discord.com/oauth2/authorize?client_id=1320058519642177668&permissions=8&scope=bot%20applications.commands" class="btn btn-glass btn-pulse" target="_blank">Invite Bot</a>
            </div>
        </header>

        <section class="section reveal" id="features">
            <h2 class="section-title">Verified Core Systems</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <span class="feature-icon">💳</span>
                    <h3>Nexus Vaults</h3>
                    <p>Experience a fully balanced network credit system with terminal gigs, cyber-heists, and daily cache allocations.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">🎰</span>
                    <h3>High-Stakes Interface</h3>
                    <p>Test your luck with Blackjack and Slots within a sleek, low-latency glassmorphism UI container.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">🛡️</span>
                    <h3>Elite Node Control</h3>
                    <p>Secure your network environment with bulk purging, firewall verification tools, and administrative oversight commands.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">📈</span>
                    <h3>Reputation & XP</h3>
                    <p>Reward your most active operatives with a beautiful reputation tracking system and sequential ranking profiles.</p>
                </div>
            </div>
        </section>

        <section class="section reveal" id="commands">
            <h2 class="section-title">Explore Commands</h2>
            <div class="commands-wrapper">
                <div class="search-container">
                    <span class="search-icon">🔍</span>
                    <input type="text" class="search-input" id="command-search" placeholder="Search for a command (e.g. blackjack)...">
                </div>
                
                <div class="category-tabs" id="category-tabs">
                    <div class="category-tab active" data-category="utility">🔧 Utility</div>
                    <div class="category-tab" data-category="economy">💰 Economy</div>
                    <div class="category-tab" data-category="casino">🎰 Casino</div>
                    <div class="category-tab" data-category="leveling">📈 Leveling</div>
                    <div class="category-tab" data-category="moderation">🛡️ Moderation</div>
                    <div class="category-tab" data-category="fun">🎲 Fun</div>
                    <div class="category-tab" data-category="media">📸 Media</div>
                </div>

                <div class="command-list" id="command-list">
                    <!-- commands will be injected here by script.js -->
                </div>
            </div>
        </section>

        <footer>
            <div class="joke-of-the-day" id="joke-box">
                <span class="joke-tag">Joke of the Day</span>
                <p id="daily-joke">Loading a laugh...</p>
            </div>
            <p>&copy; 2026 NexusBot. Created with ❤️ by watispro5212, watispro1.</p>
            <div class="footer-links">
                <a href="privacy.html">Privacy Policy</a>
                <a href="terms.html">Terms of Service</a>
            </div>
        </footer>
    </div>

    <script src="script.js"></script>
</body>
</html>
