<nav>
    <div class="container nav-content">
        <a href="/" class="logo">
            <span>NexusBot</span>
            <svg class="verified-badge" viewBox="0 0 24 24" fill="var(--primary)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </a>
        <div class="nav-links">
            <% if (typeof isHome !== 'undefined' && isHome) { %>
                <a href="#features">Features</a>
                <a href="#commands">Commands</a>
            <% } %>
            
            <% if (locals.user) { %>
                <a href="/dashboard" class="user-profile-link">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" class="nav-avatar">
                    <%= user.username %>
                </a>
                <a href="/api/auth/logout" style="color: var(--danger);">Logout</a>
            <% } else { %>
                <a href="/api/auth/login" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Login</a>
            <% } %>
        </div>
    </div>
</nav>
